# Catalystic backend environment example
# Copy this file to catalystic-backend/.env and replace placeholders locally.
# Never commit real API keys or credentials.

# Legacy SEC flow only
SEC_API_KEY=your_sec_api_key_here

# Active Alpha Vantage flow
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
ALPHA_VANTAGE_TICKERS=AAPL,MSFT,NVDA,TSLA,AMZN
ALPHA_VANTAGE_MAX_TICKERS=5
ALPHA_VANTAGE_NEWS_PER_TICKER=5
ALPHA_VANTAGE_FETCH_EXPERT_CONTEXT=true
ALPHA_VANTAGE_REQUEST_INTERVAL_SECONDS=1.2

# Supabase backend credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_or_backend_key_here
