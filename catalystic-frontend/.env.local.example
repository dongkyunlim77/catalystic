# Catalystic frontend environment example
# Copy this file to catalystic-frontend/.env.local and replace placeholders locally.
# Only NEXT_PUBLIC_* variables should be used in frontend code.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_FOCUS_TICKERS=PLTR
